{
  "expo": {
    "name": "Stock Announcements",
    "slug": "stock-announcements",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00b386"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stockalerts.announcements"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00b386"
      },
      "package": "com.stockalerts.announcements"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
